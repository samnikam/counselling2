# Copy to .env and fill in. In production every value below marked (required) must be set.

NODE_ENV=development
PORT=3000

# (required) PostgreSQL connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/anantnag_portal
# Set to "require" for most managed Postgres (Render/Railway/Supabase/Neon).
PGSSL=

# (required in production) 32+ random chars. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# First admin, seeded once on an empty database. (ADMIN_PASSWORD required in production.)
ADMIN_EMAIL=admin@dyedc-anantnag.gov.in
ADMIN_PASSWORD=

# Comma-separated extra origins allowed to call the API (only if the frontend is hosted separately).
ALLOWED_ORIGINS=

# Where uploaded files are stored. Use a mounted persistent volume in production.
UPLOAD_DIR=
MAX_UPLOAD_MB=25
